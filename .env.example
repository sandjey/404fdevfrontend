# =============================================================
# Frontend env (Next.js)
# Production'da .env.local yoki Vercel/Cloudflare environment'iga
# qo'ying. NEXT_PUBLIC_* o'zgaruvchilar mijoz brauzeriga chiqadi.
# =============================================================

# ---- Core ----
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=uz

# ---- SEO: Search engine site verification ----
# 1. Google Search Console → "URL prefix" → ".com prefix" → HTML tag
#    → ko'rinadi: <meta name="google-site-verification" content="XXXX">
#    XXXX qiymatini shu yerga yozing.
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# 2. Yandex Webmaster → "Sayt qo'shish" → HTML-tag → content="YYYY"
NEXT_PUBLIC_YANDEX_VERIFICATION=

# 3. Bing Webmaster → "Add a site" → Meta tag → content="ZZZZ"
NEXT_PUBLIC_BING_VERIFICATION=

# ---- Analytics ----
# Google Analytics 4 — propertyni yarating va Measurement ID ("G-XXXXXXXXXX") oling.
NEXT_PUBLIC_GA_ID=

# Yandex Metrica — counter ID (faqat raqam, masalan: 12345678)
NEXT_PUBLIC_YM_ID=
